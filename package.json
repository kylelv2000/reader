{
  "name": "yomu-reader",
  "version": "1.4.2",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && NODE_ENV=test node --test tests/reader-text.test.mjs tests/rendered-html.test.mjs services/web-runtime/server.test.mjs services/security-gateway/server.test.mjs",
    "test:security:smoke": "node scripts/security-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.6",
    "opencc-js": "1.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5"
  },
  "overrides": {
    "postcss": "8.5.14",
    "fast-uri": "3.1.4",
    "sharp": "0.35.3"
  },
  "type": "module"
}
