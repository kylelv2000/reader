# ============================================================
# Yomu Reader 部署配置
# 复制为 deploy/.env 后按下方说明修改。
#   cp deploy/.env.example deploy/.env
# 生成随机密钥：openssl rand -hex 32
# ============================================================

# ---------- 必填（3 项） ----------

# 你从浏览器访问阅读器的完整地址。
# - 有域名和 HTTPS（推荐）：https://reader.example.com
# - 仅本机测试：http://localhost:8080（同时把下面 YOMU_COOKIE_SECURE 改为 false）
YOMU_PUBLIC_ORIGIN=https://reader.example.com

# 登录会话加密密钥。填 32 位以上随机字符串，泄露等于泄露所有登录态。
YOMU_SESSION_SECRET=replace-with-at-least-32-random-characters

# 服务器管理密钥（相当于超级管理员密码），用于管理用户等内部操作。
# 填长随机字符串，不要告诉任何人，浏览器端永远不需要它。
READER_SECURE_KEY=replace-with-a-long-random-admin-secret

# ---------- 首次部署需要 ----------

# 初始化邀请码：仅在创建首位管理员账号那一步用到，同样填随机字符串。
READER_INVITE_CODE=replace-with-a-private-bootstrap-invite-code

# ---------- 常用可选 ----------

# 镜像版本。latest 表示最新发布；也可固定版本号如 1.2.2 以便回滚。
YOMU_IMAGE_VERSION=latest

# 服务监听的本机端口（只绑定 127.0.0.1，由你的反向代理转发到它）。
YOMU_PORT=8080

# 数据存储位置：
# - 默认 reader-storage：使用 Docker 数据卷（推荐，升级不丢数据）
# - 填服务器绝对路径（如 /srv/reader-data）：直接存到该目录，便于备份
#   或迁移旧 Reader Pro 数据（指向旧数据目录即可自动迁移）。
READER_STORAGE=reader-storage

# Cookie 仅通过 HTTPS 传输。有 HTTPS 保持 true；localhost 测试改 false。
YOMU_COOKIE_SECURE=true

# ---------- 进阶（保持默认即可） ----------

# 登录有效期（秒）。默认 604800 = 7 天，之后需重新登录。
YOMU_SESSION_TTL_SECONDS=604800

# 普通 API 请求体上限（字节）。默认 2MB。
YOMU_MAX_BODY_BYTES=2097152

# 上传文件（本地书/备份导入）大小上限（字节）。默认 100MB。
YOMU_MAX_UPLOAD_BYTES=104857600

# 是否启用多用户与登录（false 表示无认证单人模式，勿用于公网）。
READER_SECURE=true

# 最多允许的注册用户数。
READER_USER_LIMIT=10

# 每个用户书架的书籍数量上限。
READER_USER_BOOK_LIMIT=2000

# 每个普通用户自有书源数量上限（0 = 不限）。管理员维护的系统书源
# 对全部用户自动生效、不占用户额度，用户额外添加的书源受此限制。
READER_USER_SOURCE_LIMIT=50

# 单次搜索最多使用的书源数（按每用户的优先级取前 N 个，0 = 不限）。
# 与 READER_MAX_OUTBOUND_CONCURRENT 一起控制搜索负载。
READER_SEARCH_SOURCE_LIMIT=200

# 抓取书源网站的单次请求超时（秒）。网络差可调大到 30。
READER_REQUEST_TIMEOUT_SECS=20

# 同时向外部书源网站发起的最大请求数（全局池，所有用户共享）。
# 内存/带宽小的机器可调低到 8–16；大机器可调到 64。
READER_MAX_OUTBOUND_CONCURRENT=32

# 换源扫描的搜索并发路数（每路一个搜索请求）。
READER_SCAN_SEARCH_CONCURRENT=12
# 换源扫描的目录校验并发路数（每路约 2 个请求，建议约为搜索的一半）。
READER_SCAN_VALIDATE_CONCURRENT=6
# 封面抓取并发路数（独立通道，不占上面的全局池）。
READER_COVER_CONCURRENT=8

# reader-core 容器内存上限。默认 1g；小内存机器可改 512m。
READER_CORE_MEM_LIMIT=1g

# 日志级别：error / warn / info / debug。
READER_LOG_LEVEL=info

# ---------- WebView 书源（可选，多数人用不到） ----------
# 个别书源的规则需要真实浏览器执行 JS 才能抓取。启用方法：
# 1. 取消注释下面两行并把 KEY 换成随机字符串；
# 2. 启动时追加 --profile webview。
# 注意会常驻一个约 800MB 内存的 Chromium 容器。

# WEBVIEW_BRIDGE_URL=http://webview-bridge:19090
# WEBVIEW_BRIDGE_KEY=replace-with-a-long-random-bridge-secret

# WebView 并发页面数（默认 1，个人使用足够）。
WEBVIEW_MAX_CONCURRENT=1
# Chromium 空闲多少秒后自动退出省内存。
WEBVIEW_IDLE_SECONDS=120
# WebView 抓取的响应大小上限（字节）。默认 8MB。
WEBVIEW_MAX_RESPONSE_BYTES=8388608
