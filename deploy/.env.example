# ============================================================
# Yomu Reader 可选配置
#
# 所有配置都有合理默认值，本文件整个是可选的：
# 不创建 .env 也能直接 `docker compose up -d` 启动。
# 需要修改时复制为同目录 .env 并取消对应行的注释：
#   cp .env.example .env
# ============================================================

# ---------- 公网部署（有域名时填这一项就够了） ----------

# 浏览器访问阅读器的完整地址。配置后启用严格来源校验和 HTTPS Cookie。
# 留空 = 本地模式（http://localhost:8080，局域网口味见 YOMU_BIND）。
#YOMU_PUBLIC_ORIGIN=https://reader.example.com

# ---------- 常用 ----------

# 服务监听端口（默认只绑定本机 127.0.0.1，由反向代理转发）。
#YOMU_PORT=8080

# 改成 0.0.0.0 可让局域网设备直接访问（无反向代理的家庭内网场景）。
#YOMU_BIND=127.0.0.1

# 初始管理员（仅首次启动生效）。默认用户名 admin、密码自动生成，
# 初始密码在日志里：docker compose logs reader-core | grep admin
#YOMU_ADMIN_USERNAME=admin
#YOMU_ADMIN_PASSWORD=

# 数据位置。默认 Docker 卷；填服务器绝对路径可直接落盘、便于备份，
# 也可指向旧 Reader Pro 数据目录自动迁移。
#READER_STORAGE=/srv/yomu-data

# 镜像版本。latest 表示最新发布；可固定版本号（如 1.4.0）便于回滚。
#YOMU_IMAGE_VERSION=latest

# ---------- 配额 ----------

# 最多允许的用户数。
#READER_USER_LIMIT=10
# 每用户书架书籍上限。
#READER_USER_BOOK_LIMIT=2000
# 每个普通用户自有书源上限（0 不限）；管理员书源全员共享、不占额度。
#READER_USER_SOURCE_LIMIT=50

# ---------- 性能（默认适合 2 核 2G 以上机器） ----------

# 对外抓取的全局并发池（所有用户共享）。小机器 16，大机器 64。
#READER_MAX_OUTBOUND_CONCURRENT=32
# 单次搜索最多使用的书源数（按用户优先级取前 N，0 不限）。
#READER_SEARCH_SOURCE_LIMIT=200
# 换源扫描：搜索并发路数 / 目录校验并发路数（校验开销约为搜索 2 倍）。
#READER_SCAN_SEARCH_CONCURRENT=12
#READER_SCAN_VALIDATE_CONCURRENT=6
# 封面抓取并发（独立通道，不占全局池）。
#READER_COVER_CONCURRENT=8
# 抓取书源网站的单次请求超时（秒）。网络差可调大到 30。
#READER_REQUEST_TIMEOUT_SECS=20
# reader-core 容器内存上限。小内存机器可改 512m。
#READER_CORE_MEM_LIMIT=1g

# ---------- 进阶（一般不用动） ----------

# 登录会话密钥与有效期。密钥默认自动生成并持久化。
#YOMU_SESSION_SECRET=
#YOMU_SESSION_TTL_SECONDS=604800
# Cookie 是否仅 HTTPS。默认自动：配置了 https 域名为 true，否则 false。
#YOMU_COOKIE_SECURE=
# 内部管理密钥。默认自动生成并保存在数据卷。
#READER_SECURE_KEY=
# 普通请求体 / 上传文件大小上限（字节）。
#YOMU_MAX_BODY_BYTES=2097152
#YOMU_MAX_UPLOAD_BYTES=104857600
# 日志级别：error / warn / info / debug。
#READER_LOG_LEVEL=info

# ---------- WebView 书源（可选，多数人用不到） ----------
# 个别书源需要真实浏览器执行 JS。启用：设置下面两项并在启动命令
# 加 --profile webview。注意会常驻一个约 800MB 内存的 Chromium。
#WEBVIEW_BRIDGE_URL=http://webview-bridge:19090
#WEBVIEW_BRIDGE_KEY=replace-with-a-long-random-bridge-secret
#WEBVIEW_MAX_CONCURRENT=1
#WEBVIEW_IDLE_SECONDS=120
#WEBVIEW_MAX_RESPONSE_BYTES=8388608
